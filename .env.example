# Server Configuration
PORT=3000

# ── Authentication ──────────────────────────────────────────
# Choose ONE of:
#   API_KEY=<secret>     Enable bearer-token auth (recommended)
#   OPEN_MODE=true       Disable auth (NOT recommended for shared servers)
API_KEY=replace-me-with-a-random-secret
# OPEN_MODE=true

# ── Ritual Chain ────────────────────────────────────────────
RITUAL_RPC_URL=https://rpc.ritualfoundation.org

# ── Encryption ──────────────────────────────────────────────
# Server-side key for encrypting wallet shards at rest (32 bytes hex).
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Server will REFUSE TO START if this is missing or all-zeros.
ENCRYPTION_KEY=

# ── Optional: Faucet ────────────────────────────────────────
# A funded EOA's private key used to drip a fixed amount to every newly
# created wallet (one claim per wallet). Leave unset to disable the
# POST /wallets/:id/fund endpoint and fund_wallet MCP tool.
FAUCET_PRIVATE_KEY=
# Amount in RITUAL each agent can claim (default 0.01)
FAUCET_AMOUNT=0.01

# Database path
DATABASE_PATH=./data/wallets.db
