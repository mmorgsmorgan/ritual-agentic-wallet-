# Dockerfile for the @ritkey/mcp HTTP transport service.
# Builds the mcp package + its sdk dep (no Rust / no sqlite, much lighter
# than the wallet-service image).

FROM node:22-alpine AS builder
WORKDIR /app

COPY package.json package-lock.json ./
COPY packages/sdk/package.json packages/sdk/package.json
COPY packages/mcp/package.json packages/mcp/package.json
RUN npm ci --workspaces --include-workspace-root --ignore-scripts

COPY packages/sdk packages/sdk
COPY packages/mcp packages/mcp
RUN npm run build -w @ritkey/sdk \
 && npm run build -w @ritkey/mcp

RUN npm prune --omit=dev --workspaces --include-workspace-root

# ── Runtime ───────────────────────────────────────────────
FROM node:22-alpine AS runtime
WORKDIR /app
ENV NODE_ENV=production
RUN apk add --no-cache tini

COPY --from=builder /app/node_modules                  ./node_modules
COPY --from=builder /app/package.json                  ./package.json
COPY --from=builder /app/packages/sdk/dist             ./packages/sdk/dist
COPY --from=builder /app/packages/sdk/package.json     ./packages/sdk/package.json
COPY --from=builder /app/packages/mcp/dist             ./packages/mcp/dist
COPY --from=builder /app/packages/mcp/package.json     ./packages/mcp/package.json
COPY --from=builder /app/packages/mcp/skills           ./packages/mcp/skills

ENV PORT=3000
EXPOSE 3000

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["node", "packages/mcp/dist/mcp/http.js"]
